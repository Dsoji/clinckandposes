rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow any user to read the website data
    match /site/{document=**} {
      allow read: if true;
      // Allow only authenticated admin users to write to the website
      allow write: if request.auth != null;
    }
    
    // Fallback block all other queries
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
